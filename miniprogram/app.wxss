page {
  --paper-base: #f2e9d8;
  --paper-light: #faf6ec;
  --paper-deep: #e3d4ba;
  --ink-primary: #252822;
  --ink-secondary: #666154;
  --green-primary: #23483a;
  --green-dark: #173329;
  --wine-accent: #7a3136;
  --brass-accent: #a47b3d;
  --line-default: #b9aa8f;
  --error: #9a3434;
  --success: #356a4b;
  min-height: 100%;
  background-color: var(--paper-base);
  color: var(--ink-primary);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: 32rpx;
}

view,
text,
button,
input,
textarea,
scroll-view {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  border-radius: 0;
  font: inherit;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  padding: 40rpx;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
  background-color: var(--paper-base);
  background-image:
    linear-gradient(rgba(80, 65, 40, 0.025) 1px, transparent 1px),
    linear-gradient(90deg, rgba(80, 65, 40, 0.018) 1px, transparent 1px);
  background-size: 9rpx 11rpx, 13rpx 15rpx;
}

.page-with-action {
  padding-bottom: calc(164rpx + env(safe-area-inset-bottom));
}

.page-title {
  margin: 12rpx 0 16rpx;
  font-family: "Songti SC", "STSong", serif;
  font-size: 56rpx;
  font-weight: 600;
  line-height: 1.35;
}

.page-lead {
  max-width: 600rpx;
  color: var(--ink-secondary);
  font-size: 28rpx;
  line-height: 1.75;
}

.section {
  padding: 56rpx 0;
  border-bottom: 1rpx solid var(--line-default);
}

.section:last-child {
  border-bottom: 0;
}

.section-title {
  margin-bottom: 24rpx;
  font-family: "Songti SC", "STSong", serif;
  font-size: 40rpx;
  font-weight: 600;
  line-height: 1.45;
}

.section-note {
  margin-top: -10rpx;
  margin-bottom: 24rpx;
  color: var(--ink-secondary);
  font-size: 24rpx;
  line-height: 1.6;
}

.primary-button,
.secondary-button,
.danger-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-height: 96rpx;
  border-radius: 8rpx;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.2;
}

.primary-button {
  background: var(--green-primary);
  color: var(--paper-light);
}

.primary-button.button-hover {
  background: var(--green-dark);
}

.primary-button[disabled] {
  background: var(--paper-deep);
  color: var(--ink-secondary);
}

.secondary-button {
  border: 2rpx solid var(--green-primary);
  background: transparent;
  color: var(--green-primary);
}

.danger-button {
  border: 2rpx solid rgba(154, 52, 52, 0.45);
  background: transparent;
  color: var(--error);
}

.fixed-action {
  position: fixed;
  z-index: 20;
  right: 0;
  bottom: 0;
  left: 0;
  padding: 20rpx 40rpx calc(20rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(185, 170, 143, 0.75);
  background: rgba(242, 233, 216, 0.96);
}

.fixed-action-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
}

.field-label {
  display: block;
  margin-bottom: 14rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.text-input,
.text-area {
  width: 100%;
  border: 2rpx solid var(--line-default);
  border-radius: 8rpx;
  background: var(--paper-light);
  color: var(--ink-primary);
  font-size: 30rpx;
}

.text-input {
  min-height: 96rpx;
  padding: 0 24rpx;
}

.text-area {
  min-height: 240rpx;
  padding: 24rpx;
  line-height: 1.65;
}

.field-placeholder {
  color: #8b8475;
}

.field-error {
  margin-top: 12rpx;
  color: var(--error);
  font-size: 24rpx;
  line-height: 1.5;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  min-height: 52rpx;
  padding: 10rpx 16rpx;
  border: 1rpx solid var(--line-default);
  border-radius: 4rpx;
  background: rgba(250, 246, 236, 0.48);
  color: var(--ink-secondary);
  font-size: 24rpx;
  line-height: 1.25;
}

.quiet-notice {
  padding: 24rpx 0 24rpx 24rpx;
  border-left: 4rpx solid var(--brass-accent);
  color: var(--ink-secondary);
  font-size: 26rpx;
  line-height: 1.7;
}

.empty-state {
  display: flex;
  min-height: 58vh;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.empty-state-title {
  margin: 32rpx 0 12rpx;
  font-family: "Songti SC", "STSong", serif;
  font-size: 40rpx;
  font-weight: 600;
}

.empty-state-copy {
  max-width: 520rpx;
  margin-bottom: 40rpx;
  color: var(--ink-secondary);
  font-size: 28rpx;
  line-height: 1.7;
}

.enter {
  animation: enter 220ms ease-out both;
}

@keyframes enter {
  from { opacity: 0; transform: translateY(12rpx); }
  to { opacity: 1; transform: translateY(0); }
}

