.recognition-result { padding-bottom: calc(72rpx + env(safe-area-inset-bottom)); }
.result-kicker { margin-top: 28rpx; color: var(--wine-accent); font-size: 22rpx; text-align: center; }
.result-title { margin-top: 14rpx; font-family: "Songti SC", "STSong", serif; font-size: 64rpx; font-weight: 600; line-height: 1.3; text-align: center; }
.compact-title { font-size: 50rpx; }
.result-english { margin-top: 8rpx; color: var(--ink-secondary); font-family: Georgia, serif; font-size: 26rpx; text-align: center; }
.result-summary { max-width: 600rpx; margin: 32rpx auto 0; font-size: 30rpx; line-height: 1.8; text-align: center; }
.result-tag-list { justify-content: center; margin-top: 30rpx; }

.profile-row { display: flex; min-height: 70rpx; align-items: flex-start; justify-content: space-between; gap: 30rpx; border-bottom: 1rpx solid rgba(185,170,143,.55); color: var(--ink-secondary); font-size: 26rpx; line-height: 1.6; }
.profile-row + .profile-row { padding-top: 18rpx; }
.profile-value { display: flex; flex-wrap: wrap; justify-content: flex-end; gap: 8rpx 18rpx; color: var(--ink-primary); text-align: right; }
.ingredient-list { display: flex; flex-wrap: wrap; gap: 16rpx 28rpx; font-size: 28rpx; line-height: 1.6; }
.ingredient-list text::before { margin-right: 10rpx; color: var(--wine-accent); content: "·"; }
.extra-line { margin-top: 24rpx; color: var(--ink-secondary); font-size: 24rpx; }
.feeling-copy { padding-left: 28rpx; border-left: 4rpx solid var(--wine-accent); font-family: "Songti SC", "STSong", serif; font-size: 32rpx; line-height: 1.9; }
.ingredient-tag { border-color: rgba(35,72,58,.45); color: var(--green-primary); }
.role-item { display: grid; grid-template-columns: 142rpx 1fr; gap: 24rpx; padding: 24rpx 0; border-top: 1rpx solid rgba(185,170,143,.55); }
.role-name { font-family: "Songti SC", "STSong", serif; font-size: 28rpx; font-weight: 600; }
.role-copy { color: var(--ink-secondary); font-size: 26rpx; line-height: 1.7; }
.unknown-mark { display: flex; width: 108rpx; height: 108rpx; align-items: center; justify-content: center; border: 3rpx solid var(--green-primary); border-radius: 50%; color: var(--wine-accent); font-family: Georgia, serif; font-size: 64rpx; }
.unknown-notice { margin-top: 36rpx; padding: 24rpx; border: 1rpx solid var(--line-default); background: rgba(250,246,236,.35); }
.unknown-title { font-size: 26rpx; font-weight: 600; }
.unknown-copy { margin-top: 8rpx; color: var(--ink-secondary); font-size: 24rpx; line-height: 1.6; }
.reenter-button { margin-top: 48rpx; }

