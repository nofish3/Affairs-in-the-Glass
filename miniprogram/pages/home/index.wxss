.home {
  display: flex;
  min-height: 100vh;
  flex-direction: column;
  padding-top: calc(96rpx + env(safe-area-inset-top));
}

.home-header {
  position: relative;
  z-index: 2;
}

.brand-mark {
  font-family: "Songti SC", "STSong", serif;
  font-size: 80rpx;
  font-weight: 600;
  line-height: 1.1;
}

.brand-rule {
  width: 88rpx;
  height: 4rpx;
  margin: 22rpx 0;
  background: var(--wine-accent);
}

.brand-copy {
  color: var(--ink-secondary);
  font-family: "Songti SC", "STSong", serif;
  font-size: 30rpx;
}

.hero-still-life {
  position: relative;
  min-height: 520rpx;
  flex: 1;
  margin: -12rpx -40rpx 8rpx;
  overflow: hidden;
}

.hero-image {
  position: absolute;
  top: 0;
  right: -8rpx;
  width: 680rpx;
  height: auto;
}

.entry-list {
  border-top: 2rpx solid var(--ink-primary);
}

.entry-item {
  display: grid;
  width: 100%;
  min-height: 128rpx;
  grid-template-columns: 72rpx 1fr 52rpx;
  align-items: center;
  border-bottom: 1rpx solid var(--line-default);
  background: transparent;
  color: var(--ink-primary);
  text-align: left;
}

.entry-hover {
  background: rgba(35, 72, 58, 0.07);
}

.entry-number {
  color: var(--wine-accent);
  font-family: Georgia, serif;
  font-size: 24rpx;
}

.entry-title {
  font-family: "Songti SC", "STSong", serif;
  font-size: 38rpx;
  font-weight: 600;
}

.entry-subtitle {
  margin-top: 6rpx;
  color: var(--ink-secondary);
  font-size: 24rpx;
}

.entry-arrow {
  color: var(--green-primary);
  font-size: 42rpx;
  text-align: right;
}

.responsible-note {
  padding-top: 28rpx;
  color: var(--ink-secondary);
  font-size: 20rpx;
  text-align: center;
}
