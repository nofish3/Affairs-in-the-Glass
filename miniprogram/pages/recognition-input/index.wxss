.search-illustration {
  position: relative;
  height: 284rpx;
  margin: 34rpx -40rpx 24rpx;
  overflow: hidden;
}

.search-image {
  position: absolute;
  bottom: 0;
  left: 20rpx;
  width: 730rpx;
  height: auto;
}

.input-section { padding-top: 8rpx; }
.recognition-form { border-top: 2rpx solid var(--ink-primary); }
.recognition-field { display: block; padding: 32rpx 0 36rpx; border-bottom: 1rpx solid var(--line-default); }
.recognition-area { height: 190rpx; min-height: 190rpx; }
.optional-mark {
  margin-left: 8rpx;
  color: var(--ink-secondary);
  font-size: 22rpx;
  font-weight: 400;
}
.recognition-notice { margin-top: 38rpx; }
