.taste-head,
.taste-row {
  display: grid;
  grid-template-columns: 112rpx repeat(3, 1fr);
  align-items: center;
}

.taste-head {
  height: 56rpx;
  color: var(--ink-secondary);
  font-size: 22rpx;
  text-align: center;
}

.taste-row {
  min-height: 92rpx;
  border-top: 1rpx solid rgba(185, 170, 143, 0.62);
}

.taste-name {
  font-family: "Songti SC", "STSong", serif;
  font-size: 32rpx;
  font-weight: 600;
}

.taste-level {
  display: flex;
  width: 100%;
  height: 64rpx;
  align-items: center;
  justify-content: center;
  border-right: 1rpx solid var(--line-default);
  background: rgba(250, 246, 236, 0.4);
  color: var(--ink-secondary);
  font-size: 26rpx;
  transition: background-color 140ms ease, color 140ms ease;
}

.taste-level:nth-child(2) { border-radius: 8rpx 0 0 8rpx; }
.taste-level:last-child { border-right: 0; border-radius: 0 8rpx 8rpx 0; }

.is-selected {
  border-color: var(--green-primary) !important;
  background: var(--green-primary) !important;
  color: var(--paper-light) !important;
}

.choice-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.choice-grid-four {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.choice-wrap {
  position: relative;
}

.choice {
  display: flex;
  width: 100%;
  min-height: 84rpx;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  border: 2rpx solid var(--line-default);
  border-radius: 8rpx;
  background: rgba(250, 246, 236, 0.38);
  color: var(--ink-primary);
  font-size: 28rpx;
  transition: background-color 140ms ease, color 140ms ease, border-color 140ms ease;
}

.check { font-size: 22rpx; }

.info-button {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  display: flex;
  width: 44rpx;
  height: 44rpx;
  align-items: center;
  justify-content: center;
  border: 1rpx solid currentColor;
  border-radius: 50%;
  background: transparent;
  color: var(--ink-secondary);
  font-family: Georgia, serif;
  font-size: 22rpx;
}

.validation-summary { margin-top: 28rpx; }

