.taste-head,
.taste-row {
  display: flex;
  width: 100%;
  align-items: center;
}

.taste-head > text:first-child,
.taste-name {
  width: 84rpx;
  flex: 0 0 84rpx;
}

.taste-head > text:not(:first-child),
.taste-level {
  min-width: 0;
  flex: 1 1 0;
}

.taste-head {
  height: 56rpx;
  color: var(--ink-secondary);
  font-size: 22rpx;
  text-align: center;
}

.taste-row {
  min-height: 92rpx;
  border-top: 1rpx solid rgba(185, 170, 143, 0.62);
}

.taste-name {
  font-family: "Songti SC", "STSong", serif;
  font-size: 32rpx;
  font-weight: 600;
}

.taste-level {
  display: flex;
  height: 64rpx;
  align-items: center;
  justify-content: center;
  border-right: 1rpx solid var(--line-default);
  background: rgba(250, 246, 236, 0.4);
  color: var(--ink-secondary);
  font-size: 26rpx;
  transition: background-color 140ms ease, color 140ms ease;
}

.taste-level:nth-child(2) { border-radius: 8rpx 0 0 8rpx; }
.taste-level:last-child { border-right: 0; border-radius: 0 8rpx 8rpx 0; }

.is-selected {
  border-color: var(--green-primary) !important;
  background: var(--green-primary) !important;
  color: var(--paper-light) !important;
}

.choice-grid {
  display: flex;
  width: 100%;
  flex-wrap: wrap;
  gap: 16rpx;
}

.choice {
  display: flex;
  width: calc(50% - 8rpx);
  min-width: 0;
  min-height: 84rpx;
  flex: 0 0 calc(50% - 8rpx);
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  border: 2rpx solid var(--line-default);
  border-radius: 8rpx;
  background: rgba(250, 246, 236, 0.38);
  color: var(--ink-primary);
  font-size: 28rpx;
  transition: background-color 140ms ease, color 140ms ease, border-color 140ms ease;
}

.choice-label {
  display: flex;
  min-width: 0;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.choice-hint {
  color: var(--ink-secondary);
  font-size: 20rpx;
  line-height: 1.25;
}

.aroma-choice.is-selected .choice-hint {
  color: rgba(250, 246, 236, 0.78);
}

.check { font-size: 22rpx; }

.validation-summary { margin-top: 28rpx; }

@media (max-width: 340px) {
  .taste-head > text:first-child,
  .taste-name {
    width: 68rpx;
    flex-basis: 68rpx;
  }

  .choice-grid { gap: 12rpx; }
  .choice {
    width: calc(50% - 6rpx);
    flex-basis: calc(50% - 6rpx);
    font-size: 26rpx;
  }
}
