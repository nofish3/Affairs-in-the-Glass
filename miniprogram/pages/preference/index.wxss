.taste-row {
  display: flex;
  width: 100%;
  align-items: center;
}

.taste-name {
  width: 96rpx;
  flex: 0 0 96rpx;
}

.taste-level {
  min-width: 0;
  flex: 1 1 0;
}

.taste-row {
  min-height: 92rpx;
  border-top: 1rpx solid rgba(185, 170, 143, 0.62);
}

.taste-name {
  font-family: "Songti SC", "STSong", serif;
  font-size: 32rpx;
  font-weight: 600;
  white-space: nowrap;
}

.taste-level {
  display: flex;
  height: 64rpx;
  align-items: center;
  justify-content: center;
  border-right: 1rpx solid var(--line-default);
  background: rgba(250, 246, 236, 0.4);
  color: var(--ink-secondary);
  font-size: 26rpx;
  transition: background-color 140ms ease, color 140ms ease;
}

.taste-level::after,
.selector-option::after {
  border: 0;
}

.taste-level:nth-child(2) { border-radius: 8rpx 0 0 8rpx; }
.taste-level:last-child { border-right: 0; border-radius: 0 8rpx 8rpx 0; }

.is-selected {
  border-color: var(--green-primary) !important;
  background: var(--green-primary) !important;
  color: var(--paper-light) !important;
}

.selector-row {
  display: block;
  width: 100%;
}

.selector-option {
  display: flex;
  width: 100%;
  min-width: 0;
  height: 64rpx;
  align-items: center;
  justify-content: center;
  border-bottom: 1rpx solid rgba(185, 170, 143, 0.62);
  background: rgba(250, 246, 236, 0.4);
  color: var(--ink-secondary);
  font-size: 26rpx;
  line-height: 1.2;
  white-space: nowrap;
  transition: background-color 140ms ease, color 140ms ease, border-color 140ms ease;
}

.selector-option:first-child {
  border-radius: 8rpx 8rpx 0 0;
}

.selector-option:last-child {
  border-bottom: 0;
  border-radius: 0 0 8rpx 8rpx;
}

.selector-option-random {
  border-bottom: 0;
  border-radius: 8rpx;
}

.validation-summary { margin-top: 28rpx; }

@media (max-width: 340px) {
  .taste-name {
    width: 80rpx;
    flex-basis: 80rpx;
  }

  .selector-option { font-size: 24rpx; }
}
